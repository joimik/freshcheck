# FreshCheck runs with no API keys by default.
# Open Food Facts (barcode), Tesseract.js (OCR), and TheMealDB (recipes) are all free.
#
# If you ever want to upgrade photo extraction or recipes to Claude,
# add your key in server/.env:
# ANTHROPIC_API_KEY=sk-ant-...
#
# Server port:
# PORT=3001
#
# Client API URL (set in client/.env):
# VITE_API_URL=http://localhost:3001
